# Uygulama
APP_NAME=Oyla
APP_ENV=development              # development | testing | staging | production
APP_URL=https://oyla.local
APP_DEBUG=true                   # production'da MUTLAKA false
APP_TIMEZONE=Europe/Istanbul

# ZORUNLU SECRET'LAR — production'da fallback YOK.
# Üretmek için:
#   php -r "echo bin2hex(random_bytes(32)) . PHP_EOL;"
APP_SECRET=
TOKEN_SECRET=

# Veritabanı
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=oyla
DB_USER=oyla_user
DB_PASS=                         # min 12 karakter, production'da rastgele üret
MYSQL_ROOT_PASSWORD=             # docker-compose root parolası

# Token
TOKEN_EXPIRE_MINUTES=120

# SMS (Netgsm)
SMS_PROVIDER=netgsm
SMS_MOCK=true                    # production'da false
NETGSM_USERNAME=
NETGSM_PASSWORD=
NETGSM_FROM=OYLA

# Dosya yükleme
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED=jpg,jpeg,png,webp
UPLOAD_PATH=/var/www/html/public/uploads/photos

# KVKK / data retention (gün)
PII_RETENTION_DAYS=365

# Demo seed yüklensin mi (sadece development) — production'da kesinlikle false
SEED_DEMO_DATA=false
