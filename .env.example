# Uygulama
APP_NAME=Oyla
APP_ENV=development
APP_URL=http://localhost
APP_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
APP_DEBUG=true
APP_TIMEZONE=Europe/Istanbul

# Veritabanı
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=oyla
DB_USER=oyla_user
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# Token
TOKEN_SECRET=CHANGE_ME_ANOTHER_RANDOM_STRING
TOKEN_EXPIRE_MINUTES=120

# SMS (Netgsm)
SMS_PROVIDER=netgsm
SMS_MOCK=true
NETGSM_USERNAME=
NETGSM_PASSWORD=
NETGSM_FROM=OYLA

# Dosya yükleme
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED=jpg,jpeg,png,webp
UPLOAD_PATH=/var/www/html/public/uploads/photos
