{
    "name": "barisozyurt/oyla",
    "description": "Türk dernekleri için dijital seçim yönetim sistemi",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "endroid/qr-code": "^5.0",
        "tecnickcom/tcpdf": "^6.6",
        "vlucas/phpdotenv": "^5.5",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11"
    },
    "scripts": {
        "test":      "phpunit",
        "stan":      "phpstan analyse",
        "coverage":  "XDEBUG_MODE=coverage phpunit --coverage-text --coverage-html=build/coverage"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": ["app/Core/helpers.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
